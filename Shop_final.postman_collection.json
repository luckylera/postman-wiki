    {
      "name": "Update item",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Проверка ответа на UPDATE\r",
              "var response = pm.response.json();\r",
              "\r",
              "pm.test(\"Товар успешно обновлён\", function () {\r",
              "    pm.expect(response.result).to.eql(\"Товар обновлен!\");\r",
              "});\r",
              "\r",
              "// Читаем тело реквеста и парсим XML\r",
              "const rawBody = pm.request.body.raw;\r",
              "const resolvedBody = pm.variables.replaceIn(rawBody);\r",
              "\r",
              "const getXmlValue = (xml, tag) => {\r",
              "    const match = xml.match(new RegExp(`<${tag}>([\\\\s\\\\S]*?)<\\\\/${tag}>`));\r",
              "    return match ? match[1].trim() : null;\r",
              "};\r",
              "\r",
              "const reqId          = getXmlValue(resolvedBody, \"id\");\r",
              "const reqName        = getXmlValue(resolvedBody, \"name\");\r",
              "const reqSection     = getXmlValue(resolvedBody, \"section\");\r",
              "const reqDescription = getXmlValue(resolvedBody, \"description\");\r",
              "const reqSize        = getXmlValue(resolvedBody, \"size\");\r",
              "const reqColor       = getXmlValue(resolvedBody, \"color\");\r",
              "const reqPrice       = getXmlValue(resolvedBody, \"price\");\r",
              "const reqParams      = getXmlValue(resolvedBody, \"params\");\r",
              "\r",
              "// GET-запрос для проверки сохранённых данных\r",
              "const getUrl = pm.environment.get(\"url\") + \"/api/items/get\";\r",
              "const body = { \"id\": parseInt(reqId) };\r",
              "\r",
              "const getItem = {\r",
              "    url: getUrl,\r",
              "    method: \"GET\",\r",
              "    header: \"Content-Type:application/json\",\r",
              "    body: {\r",
              "        mode: \"raw\",\r",
              "        raw: JSON.stringify(body)\r",
              "    }\r",
              "};\r",
              "\r",
              "pm.sendRequest(getItem, function (err, res) {\r",
              "    if (err) {\r",
              "        console.error(\"Ошибка GET-запроса:\", err);\r",
              "        return;\r",
              "    }\r",
              "\r",
              "    const item = res.json().result;\r",
              "\r",
              "    pm.test(`id = ${reqId}`, function () {\r",
              "        pm.expect(String(item.id)).to.eql(reqId);\r",
              "    });\r",
              "\r",
              "    pm.test(`name = ${reqName}`, function () {\r",
              "        pm.expect(item.name).to.eql(reqName);\r",
              "    });\r",
              "\r",
              "    pm.test(`section = ${reqSection}`, function () {\r",
              "        pm.expect(String(item.section)).to.eql(reqSection);\r",
              "    });\r",
              "\r",
              "    pm.test(`description = ${reqDescription}`, function () {\r",
              "        pm.expect(item.description).to.eql(reqDescription);\r",
              "    });\r",
              "\r",
              "    pm.test(`size = ${reqSize}`, function () {\r",
              "        pm.expect(String(item.size)).to.eql(reqSize);\r",
              "    });\r",
              "\r",
              "    pm.test(`color = ${reqColor}`, function () {\r",
              "        pm.expect(String(item.color)).to.eql(reqColor);\r",
              "    });\r",
              "\r",
              "    pm.test(`price = ${reqPrice}`, function () {\r",
              "        pm.expect(String(item.price)).to.eql(reqPrice);\r",
              "    });\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],

  "item": [
    {
      "name": "Address geocoder",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const response = pm.response.json();",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response contains address data\", function () {",
              "    pm.expect(response).to.be.an(\"array\").that.is.not.empty;",
              "});",
              "",
              "const address = response[0];",
              "",
              "pm.environment.set(\"lat\", address.geo_lat);",
              "pm.environment.set(\"long\", address.geo_lon);",
              "pm.environment.set(\"timezone\", address.timezone);",
              "",
              "console.log(\"lat:\", address.geo_lat);",
              "console.log(\"long:\", address.geo_lon);",
              "console.log(\"timezone:\", address.timezone);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
